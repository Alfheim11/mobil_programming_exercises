<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/sensor1_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Accelerometer Sensor"/>

        <Button
            android:id="@+id/sensor2_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Compass Sensor"/>

        <Button
            android:id="@+id/sensor3_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Gyroscope Sensor"/>

        <Button
            android:id="@+id/sensor4_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Humidity Sensor"/>

        <Button
            android:id="@+id/sensor5_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Light Sensor"/>

        <Button
            android:id="@+id/sensor6_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Magnometer Sensor"/>

        <Button
            android:id="@+id/sensor7_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Pressure Sensor"/>

        <Button
            android:id="@+id/sensor8_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Proximity Sensor"/>

        <Button
            android:id="@+id/sensor9_button"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:text="Thermometer Sensor"/>

    </LinearLayout>
</ScrollView>