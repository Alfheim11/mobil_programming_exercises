<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FDF8FF"
    android:padding="16dp">

    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textAlignment="center"
        android:text="0"
        android:textColor="#333333"
        android:textSize="64sp"
        android:textStyle="bold" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5"
        android:layout_marginBottom="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonKok"
            android:text="√(x"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBolY"
            android:text="x/y"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBirBoluX"
            android:text="1/x"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonUs"
            android:text="x^y"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button0"
            android:text="0"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonC"
            android:text="C"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCarp"
            android:text="*"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonTopla"
            android:text="+"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button7"
            android:text="7"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button8"
            android:text="8"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button9"
            android:text="9"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCikar"
            android:text="-"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button4"
            android:text="4"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button5"
            android:text="5"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button6"
            android:text="6"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBol"
            android:text="/"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button1"
            android:text="1"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button2"
            android:text="2"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button3"
            android:text="3"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#665FB3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEsittir"
            android:text="="
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cornerRadius="50dp"
            app:backgroundTint="#9C27B0" />

    </GridLayout>

</LinearLayout>