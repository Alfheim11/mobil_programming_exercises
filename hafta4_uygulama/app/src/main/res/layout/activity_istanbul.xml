<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <ImageView
        android:id="@+id/imgIst1"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ist2" /> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Kız Kulesi - İstanbul"
    android:textSize="20sp"
    android:textStyle="bold"
    android:textColor="#333333"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="32dp"/> <ImageView
    android:id="@+id/imgIst2"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:scaleType="centerCrop"
    android:src="@drawable/ist3" /> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Galata Kulesi - İstanbul"
    android:textSize="20sp"
    android:textStyle="bold"
    android:textColor="#333333"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="32dp"/>

    <ImageView
        android:id="@+id/imgIst3"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ist1" /> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Ayasofya - İstanbul"
    android:textSize="20sp"
    android:textStyle="bold"
    android:textColor="#333333"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="16dp"/>

</LinearLayout>
</ScrollView>